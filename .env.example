# Public values. VITE_* values are embedded in the browser bundle.
VITE_SITE_URL=http://localhost:5173
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_GA_MEASUREMENT_ID=

# Server-only secrets. Never prefix these with VITE_.
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Shippo credentials are retained only for historical labels and refunds.
SHIPPO_API_TOKEN=
SHIPPO_WEBHOOK_SECRET=
SENDCLOUD_PUBLIC_KEY=
SENDCLOUD_SECRET_KEY=
SENDCLOUD_WEBHOOK_SECRET=
# Legacy method settings are only used to read old quotes.
SENDCLOUD_SHIPPING_METHOD_ID=
SENDCLOUD_SHIPPING_METHODS={}
FREE_SHIPPING_FR_CENTS=7500
FREE_SHIPPING_EU_UK_CENTS=15000
SHIP_FROM_NAME=Zen Coffee Lab
SHIP_FROM_COMPANY=Zen Coffee Lab
SHIP_FROM_STREET1=
SHIP_FROM_STREET2=
SHIP_FROM_CITY=Tours
SHIP_FROM_POSTAL_CODE=
SHIP_FROM_COUNTRY=FR
SHIP_FROM_PHONE=
SHIP_FROM_EMAIL=contact@zencoffeelab.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Zen Coffee Lab <commandes@zencoffeelab.com>
ADMIN_NOTIFICATION_EMAIL=contact@zencoffeelab.com
CRON_SECRET=

# Local development only. Production refuses mocks.
ALLOW_DEMO_DATA=true
PAYMENTS_MOCK=true
SHIPPING_MOCK=true
DEMO_ADMIN=true
