{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zen-coffee-lab",
  "compatibility_date": "2026-07-22",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "main": "./workers/app.ts",
  "vars": {
    "NODE_ENV": "production",
    "COLISSIMO_FR_MODE": "sendcloud_only"
  },
  "observability": {
    "enabled": true
  }
}
