    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.552.0",
    "radix-ui": "^1.6.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router": "^7.18.0",
    "resend": "^6.8.0",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
